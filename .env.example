APP_NAME="eCompta360"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tondomaine.com

# ============================================================
# BASE DE DONNÉES — MySQL Hostinger
# Récupérer les infos dans hPanel > Databases
# ============================================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u123456789_compta
DB_USERNAME=u123456789_user
DB_PASSWORD=mot_de_passe_mysql

# ============================================================
# CACHE / SESSION / QUEUE — drivers FILE + DATABASE
# PAS de Redis sur hébergement mutualisé Hostinger
# ============================================================
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=480
QUEUE_CONNECTION=database

# ============================================================
# STOCKAGE PDF — disque local Hostinger
# Chemin : storage/app/private/tenants/{tenant_id}/pdfs/
# Accès uniquement via route Laravel protégée (token signé)
# ============================================================
FILESYSTEM_DISK=local

# ============================================================
# n8n CLOUD — pipeline IA externe (HTTPS public)
# Remplace le n8n Docker qui ne peut pas tourner sur mutualisé
# ============================================================
N8N_WEBHOOK_URL=https://ton-instance.app.n8n.cloud/webhook/traiter-facture
N8N_API_TOKEN=ton_token_api_n8n
N8N_SECRET=cle_hmac_secrete_minimum_32_caracteres
# URL de callback que n8n.cloud appellera en retour
N8N_CALLBACK_URL=https://tondomaine.com

# ============================================================
# APIs IA (utilisées par n8n.cloud, pas directement Laravel)
# ============================================================
MISTRAL_API_KEY=
OPENAI_API_KEY=

# ============================================================
# FEEXPAY — paiements mobile money MTN/Moov Bénin
# ============================================================
FEEXPAY_TOKEN=
FEEXPAY_CALLBACK_URL=https://tondomaine.com/webhooks/feexpay

# ============================================================
# MAIL — SMTP Hostinger (ou Gmail en backup)
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreply@tondomaine.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tondomaine.com
MAIL_FROM_NAME="ComptaSaaS"

# ============================================================
# GOOGLE SHEETS — OAuth2 (optionnel, plan Pro+)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# LOGS
# ============================================================
LOG_CHANNEL=daily
LOG_LEVEL=error
